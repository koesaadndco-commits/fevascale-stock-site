# ---- データベース（Vercel/Neon Postgres）----
# プール接続（アプリ実行時）
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# 非プール接続（prisma migrate 用）。Neon/Vercel では別ホストになる
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- 認証 ----
# セッション Cookie の署名鍵。十分に長いランダム文字列を設定
#   例: openssl rand -base64 48
APP_SECRET="change-me-to-a-long-random-string"

# ---- ファイル保存（任意・将来用）----
# Vercel Blob を使う場合のみ設定（未設定ならローカル保存にフォールバック）
# BLOB_READ_WRITE_TOKEN=""
